  color: #475569;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

.room-code-value {
  font-family: 'Courier New', monospace;
  font-size: 22px;
  font-weight: 700;
  color: #60a5fa;
  letter-spacing: 0.22em;
}

/* ── Peer IP badge ───────────────────────────────────────────────────────── */
.peer-ip-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: #94a3b8;
  background: #1e293b;
  border: 1px solid #334155;
  border-radius: 5px;
  padding: 4px 8px;
  font-family: 'Courier New', monospace;
}

.peer-ip-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #22c55e;
  box-shadow: 0 0 5px #22c55e;
}

/* ── Hop log section ─────────────────────────────────────────────────────── */
.hop-log {
  flex: 1;
  overflow-y: auto;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.hop-log::-webkit-scrollbar { width: 4px; }
.hop-log::-webkit-scrollbar-track { background: transparent; }
.hop-log::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }

.hop-log-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  color: #334155;
  font-size: 13px;
  text-align: center;
  padding: 40px 20px;
}

.hop-log-empty-icon {
  font-size: 28px;
  opacity: 0.5;
}

/* ── Hop card ────────────────────────────────────────────────────────────── */
.hop-card {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 10px 12px;
  background: #111827;
  border: 1px solid #1e293b;
  border-radius: 8px;
  border-left: 3px solid transparent;
  transition: border-left-color 0.2s;
  animation: hop-in 0.2s ease both;
}

@keyframes hop-in {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* State variants */
.hop-card.hop-ok    { border-left-color: #0ea5e9; }
.hop-card.hop-warn  { border-left-color: #f59e0b; }

.hop-number {
  font-size: 10px;
  font-weight: 600;
  color: #475569;
  width: 20px;
  flex-shrink: 0;
  padding-top: 1px;
  font-variant-numeric: tabular-nums;
}

.hop-info {
  flex: 1;
  min-width: 0;
}

.hop-city {
  font-size: 12px;
  font-weight: 500;
  color: #cbd5e1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hop-ip {
  font-family: 'Courier New', monospace;
  font-size: 11px;
  color: #64748b;
  margin-top: 2px;
}

.hop-status-ok {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(14,165,233,0.1);
  color: #0ea5e9;
  font-weight: 600;
  flex-shrink: 0;
  align-self: center;
  letter-spacing: 0.03em;
}

.hop-status-warn {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(245,158,11,0.1);
  color: #f59e0b;
  font-weight: 600;
  flex-shrink: 0;
  align-self: center;
  letter-spacing: 0.03em;
}

/* ── Divider label (inside hop log) ─────────────────────────────────────── */
.hop-log-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.hop-log-title {
  font-size: 10px;
  font-weight: 600;
  color: #475569;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  flex-shrink: 0;
}

.hop-log-rule {
  flex: 1;
  height: 1px;
  background: #1e293b;
}

.hop-count-badge {
  font-size: 10px;
  color: #334155;
  font-variant-numeric: tabular-nums;
}
